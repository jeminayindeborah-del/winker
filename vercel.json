{
  "functions": { "og.php": { "runtime": "vercel-php@0.7.2" } },
  "rewrites": [
    {
      "source": "/",
      "has": [{"type":"header","key":"user-agent","value":"(?i).*(Twitterbot|facebookexternalhit|WhatsApp|TelegramBot|Discordbot|LinkedInBot|Slackbot|Pinterest|W3C_Validator).*"}],
      "destination": "/og.php"
    }
  ]
}
